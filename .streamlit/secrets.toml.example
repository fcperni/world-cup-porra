# Copia este archivo a .streamlit/secrets.toml (NO lo subas al repo) o pega su
# contenido en Streamlit Cloud → App → Settings → Secrets.
#
# El token debe ser un PAT de GitHub con permiso de escritura de contenido
# (Fine-grained: "Contents: Read and write" sobre el repo world-cup-porra).

[github]
token = "ghp_tu_token_personal"
repo = "fcperni/world-cup-porra"
path = "data/results.json"
branch = "main"

# ---------------------------------------------------------------------------
# Analítica de uso PRIVADA (opcional). Sin esto, la app funciona igual pero no
# registra visitas y la página Admin queda deshabilitada.
#
# 1) Crea un Postgres gratis en Supabase o Neon y copia su cadena de conexión.
#    Usa el formato SQLAlchemy y añade sslmode=require (lo piden ambos):
[connections.analytics]
url = "postgresql://usuario:password@host:5432/dbname?sslmode=require"

# 2) Contraseña para entrar en la página Admin (solo tú).
[admin]
password = "una_contraseña_larga_y_secreta"
